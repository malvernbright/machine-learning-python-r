df <- read.csv("Movie_regression.csv", header = TRUE)
View(df)
## Data Preprocessing
summary(df)
df$Time_taken[is.na(df$Time_taken)] <- mean(df$Time_taken, na.rm = TRUE)
summary(df)
## Test-Train Split
install.packages("caTools")
library(caTools)
set.seed(0)
split <- sample.split(df, SplitRatio = .8)
train <- subset(df, split = TRUE)
test <- subset(df)
## Import e1071
install.packages("e1071")
library(e1071)
svmfit <- svm(Collection~., data=train, kernel = "linear",
cost = .01, scale = TRUE)
summary(svmfit)
## Predicting on test set
ypred <- predict(svmfit, test)
mse <- mean((ypred-test$Collection))
mse <- mean((ypred-test$Collection)^2)
svmfit <- svm(Collection~., data=train, kernel = "radial",
cost = .01, scale = TRUE)
summary(svmfit)
## Predicting on test set
ypred <- predict(svmfit, test)
mse <- mean((ypred-test$Collection)^2)
