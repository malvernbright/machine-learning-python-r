bestmodP <- tune.outP$best.model
summary(bestmodP)
ypredP <- predict(bestmodP,testc)
table(predict = ypredP, truth = testc$Start_Tech_Oscar)
(147+193)/506
## Radial Kernel
svmfitR <- svm(Start_Tech_Oscar~., data=testc, kernel = "radial",
gamma=1, cost=1)
tune.outR <- tune(svm, Start_Tech_Oscar~., data = testc, kernel = "radial",
ranges = list(cost=c(.001, .01, .1, 10, 100, 1000),
gamma=c(.01, .1, .5, 1, 2, 3, 4, 10, 50)),
cross = 4)
summary(tune.outR)
tune.outR <- tune(svm, Start_Tech_Oscar~., data = testc, kernel = "radial",
ranges = list(cost=c(.001, .01, .1, 10, 100, 1000),
gamma=c(.01, .1, .5, 1, 2, 3, 4, 10, 50)),
cross = 4)
summary(tune.outR)
bestmodR < tune(tune.outR)
summary(tune.outR)
bestmodR <- tune(tune.outR$best.model)
bestmodR <- tune.outR$best.model
summary(bestmodR)
ypredR <- predict(bestmodR,testc)
table(predict = ypredR, truth = testc$Start_Tech_Oscar)
