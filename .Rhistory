model_cb_best %>% compile(optimizer = 'rmsprop', loss = 'mse',
metrics = list("mean_absolute_error"))
model_cb_early <- keras_model(inputs = inputs_func, outputs = main_output)
model_cb_early %>% compile(optimizer = 'rmsprop', loss = 'mse',
